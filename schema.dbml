// MotoShop - Single Shop AI Mechanic System Database Schema
// Docs: https://dbml.dbdiagram.io/docs
// B2B System for One Mechanic Shop

Table users {
  id uuid [primary key]
  email varchar [unique, not null]
  name varchar [not null]
  role varchar [not null, note: 'owner, mechanic, customer']
  phone varchar
  address varchar
  created_at timestamp
  updated_at timestamp
}

Table customers {
  id uuid [primary key]
  user_id uuid [not null]
  phone varchar
  address varchar
  city varchar
  total_spent decimal
  created_at timestamp
  updated_at timestamp
}

Table vehicles {
  id uuid [primary key]
  customer_id uuid [not null]
  make varchar [not null]
  model varchar [not null]
  year integer [not null]
  plate_number varchar [not null]
  engine_number varchar [not null]
  vin varchar
  created_at timestamp
}

Table parts {
  id uuid [primary key]
  name varchar [not null]
  description text
  sku varchar [unique, not null]
  category varchar [note: 'brakes, tires, oils, electrical, suspension, exhaust, filters, other']
  quantity_in_stock integer [default: 0]
  min_stock_level integer [default: 5]
  unit_price decimal [not null]
  supplier varchar
  created_at timestamp
  updated_at timestamp
}

Table products {
  id uuid [primary key]
  name varchar [not null]
  description text
  category varchar
  sku varchar [unique, not null]
  unit_price decimal [not null]
  quantity_in_stock integer
  image_url varchar
  rating decimal
  created_at timestamp
}

Table appointments {
  id uuid [primary key]
  customer_id uuid [not null]
  vehicle_id uuid [not null]
  mechanic_id uuid
  scheduled_date timestamp [not null]
  scheduled_time varchar
  service_type varchar [not null]
  description text
  status varchar [not null, note: 'pending, confirmed, in_progress, completed, cancelled']
  notes text
  created_at timestamp
  updated_at timestamp
}

Table job_orders {
  id uuid [primary key]
  appointment_id uuid
  customer_id uuid [not null]
  mechanic_id uuid [not null]
  vehicle_id uuid [not null]
  title varchar [not null]
  description text
  status varchar [not null, note: 'draft, in_progress, completed, cancelled']
  parts_used jsonb
  labor_hours decimal
  labor_rate decimal
  total_cost decimal
  created_at timestamp
  completed_at timestamp
  updated_at timestamp
}

Table featured_products {
  id uuid [primary key]
  product_id uuid [not null]
  position integer
  created_at timestamp
}

Table mechanic_availability {
  id uuid [primary key]
  mechanic_id uuid [not null]
  day_of_week varchar [not null, note: 'Monday to Sunday']
  start_time varchar [not null, note: 'HH:MM format']
  end_time varchar [not null, note: 'HH:MM format']
  is_available boolean [not null, default: true]
  created_at timestamp
  updated_at timestamp
}



Table audit_logs {
  id uuid [primary key]
  user_id uuid
  action varchar [not null]
  details text
  ip_address varchar
  created_at timestamp [not null]
}

// Relationships
Ref customers_users: customers.user_id > users.id
Ref mechanic_availability_mechanic: mechanic_availability.mechanic_id > users.id
Ref vehicles_customers: vehicles.customer_id > customers.id
Ref appointments_customers: appointments.customer_id > customers.id
Ref appointments_vehicle: appointments.vehicle_id > vehicles.id
Ref appointments_mechanic: appointments.mechanic_id > users.id
Ref job_orders_customers: job_orders.customer_id > customers.id
Ref job_orders_appointment: job_orders.appointment_id > appointments.id
Ref job_orders_mechanic: job_orders.mechanic_id > users.id
Ref job_orders_vehicle: job_orders.vehicle_id > vehicles.id
Ref featured_products_products: featured_products.product_id > products.id
Ref audit_logs_users: audit_logs.user_id > users.id

